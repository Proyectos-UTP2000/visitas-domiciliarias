{
  "name": "visitas-domiciliarias",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@latest",
  "scripts": {
    "dev": "pnpm --parallel --filter @visitas/api --filter @visitas/web dev",
    "dev:api": "pnpm --filter @visitas/api dev",
    "dev:web": "pnpm --filter @visitas/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @visitas/api db:generate",
    "db:migrate": "pnpm --filter @visitas/api db:migrate",
    "db:studio": "pnpm --filter @visitas/api db:studio"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}
