generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RolUsuario {
  ADMIN_GENERAL
  ADMIN_MUNICIPAL
  SUPERVISOR
  PERSONAL_SALUD
  ACTOR_SOCIAL
}

enum TipoMunicipalidad {
  PROVINCIAL
  DISTRITAL
}

enum EstadoGrupoTrabajo {
  BORRADOR
  REGISTRADO
  VALIDADO
  APROBADO
}

enum TipoSector {
  URBANO
  RURAL
}

enum EstadoActorSocial {
  BORRADOR
  REGISTRADO
  VALIDADO
  APROBADO
}

enum TipoAccionAsignacion {
  ASIGNACION
  DESASIGNACION
}

model Usuario {
  id              String     @id @default(uuid()) @db.Uuid
  municipalidadId String?    @map("municipalidad_id") @db.Uuid
  username        String     @unique @db.VarChar(80)
  passwordHash    String     @map("password_hash") @db.Text
  rol             RolUsuario
  activo          Boolean    @default(true)
  ultimoLoginAt   DateTime?  @map("ultimo_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  municipalidad       Municipalidad?       @relation(fields: [municipalidadId], references: [id])
  passwordResetTokens PasswordResetToken[]
  actorSocial         ActorSocial?
  historialAsignaciones HistorialAsignacionTerritorial[]
  asignacionesNinos   AsignacionNinoSocial[]

  @@map("usuario")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  usuarioId String    @map("usuario_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.Text
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("password_reset_token")
}

model Municipalidad {
  id           String            @id @default(uuid()) @db.Uuid
  ubigeo       String            @db.VarChar(6)
  departamento String            @db.VarChar(100)
  provincia    String            @db.VarChar(100)
  distrito     String            @db.VarChar(100)
  codigo       String            @db.VarChar(3)
  nombre       String            @db.VarChar(150)
  tipo         TipoMunicipalidad
  prioridad    Int               @db.SmallInt
  activo       Boolean           @default(true)
  archivado    Boolean           @default(false)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  usuarios        Usuario[]
  gruposTrabajo   GrupoTrabajo[]
  sectores        Sector[]
  actoresSociales ActorSocial[]
  centrosPoblados CentroPoblado[]
  responsables    Responsable[]
  ninos           Nino[]

  @@unique([ubigeo, codigo])
  @@map("municipalidad")
}

model Entidad {
  id          String   @id @default(uuid()) @db.Uuid
  tipoEntidad String   @map("tipo_entidad") @db.VarChar(100)
  codigo      String   @db.VarChar(100)
  nombre      String   @db.VarChar(150)
  activo      Boolean  @default(true)
  archivado   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  actoresSociales ActorSocial[]

  @@unique([tipoEntidad, codigo])
  @@map("entidad")
}

model TipoActorSocial {
  id           String   @id @default(uuid()) @db.Uuid
  tipoActor    String   @map("tipo_actor") @db.VarChar(150)
  tarifaRural  Decimal  @map("tarifa_rural") @db.Decimal(10, 2)
  tarifaUrbana Decimal  @map("tarifa_urbana") @db.Decimal(10, 2)
  orden        Int      @db.SmallInt
  codigo       String   @db.VarChar(3)
  activo       Boolean  @default(true)
  archivado    Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  actoresSociales ActorSocial[]

  @@unique([codigo])
  @@map("tipo_actor_social")
}

model CargoMiembroGrupo {
  id          String   @id @default(uuid()) @db.Uuid
  nombre      String   @db.VarChar(100)
  descripcion String?  @db.Text
  orden       Int      @db.SmallInt
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  miembros MiembroGrupo[]

  @@unique([nombre])
  @@map("cargo_miembro_grupo")
}

model GrupoTrabajo {
  id                     String             @id @default(uuid()) @db.Uuid
  municipalidadId        String             @map("municipalidad_id") @db.Uuid
  fechaLimite            DateTime           @map("fecha_limite") @db.Date
  nombreGrupo            String             @map("nombre_grupo") @db.VarChar(150)
  periodoYear            Int                @map("periodo_year") @db.SmallInt
  dniRepresentante       String             @map("dni_representante") @db.VarChar(8)
  nombreRepresentante    String             @map("nombre_representante") @db.VarChar(150)
  apellidosRepresentante String             @map("apellidos_representante") @db.VarChar(200)
  estado                 EstadoGrupoTrabajo @default(BORRADOR)
  observaciones          String?            @map("observaciones") @db.Text
  activo                 Boolean            @default(true)
  archivado              Boolean            @default(false)
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  municipalidad    Municipalidad          @relation(fields: [municipalidadId], references: [id])
  establecimientos GrupoEstablecimiento[]
  miembros         MiembroGrupo[]
  actoresSociales  ActorSocial[]
  archivos         GrupoTrabajoArchivo[]

  @@index([municipalidadId])
  @@map("grupo_trabajo")
}

model GrupoEstablecimiento {
  id             String   @id @default(uuid()) @db.Uuid
  grupoTrabajoId String   @map("grupo_trabajo_id") @db.Uuid
  nombre         String   @db.VarChar(150)
  codigo         String?  @db.VarChar(50)
  direccion      String?  @db.VarChar(200)
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  grupoTrabajo GrupoTrabajo   @relation(fields: [grupoTrabajoId], references: [id])
  miembros     MiembroGrupo[]
  actoresSociales ActorSocial[]

  @@unique([grupoTrabajoId, codigo])
  @@index([grupoTrabajoId])
  @@map("grupo_establecimiento")
}

model MiembroGrupo {
  id                     String    @id @default(uuid()) @db.Uuid
  grupoTrabajoId         String    @map("grupo_trabajo_id") @db.Uuid
  grupoEstablecimientoId String?   @map("grupo_establecimiento_id") @db.Uuid
  cargoMiembroGrupoId    String    @map("cargo_miembro_grupo_id") @db.Uuid
  dni                    String    @db.VarChar(8)
  nombres                String    @db.VarChar(150)
  apellidos              String    @db.VarChar(200)
  celular                String?   @db.VarChar(9)
  email                  String?   @db.VarChar(150)
  activo                 Boolean   @default(true)
  archivado              Boolean   @default(false)
  deletedAt              DateTime? @map("deleted_at")
  motivoEliminacion      String?   @map("motivo_eliminacion") @db.Text
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  grupoTrabajo         GrupoTrabajo          @relation(fields: [grupoTrabajoId], references: [id])
  grupoEstablecimiento GrupoEstablecimiento? @relation(fields: [grupoEstablecimientoId], references: [id])
  cargoMiembroGrupo    CargoMiembroGrupo     @relation(fields: [cargoMiembroGrupoId], references: [id])

  @@index([grupoTrabajoId])
  @@index([grupoEstablecimientoId])
  @@map("miembro_grupo")
}

model Sector {
  id              String     @id @default(uuid()) @db.Uuid
  municipalidadId String     @map("municipalidad_id") @db.Uuid
  centroPobladoId String     @map("centro_poblado_id") @db.Uuid
  codigo          String     @db.VarChar(100)
  departamento    String     @db.VarChar(100)
  provincia       String     @db.VarChar(100)
  distrito        String     @db.VarChar(100)
  nombreSector    String     @map("nombre_sector") @db.VarChar(100)
  tipoSector      TipoSector @map("tipo_sector")
  activo          Boolean    @default(true)
  archivado       Boolean    @default(false)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  municipalidad   Municipalidad @relation(fields: [municipalidadId], references: [id])
  centroPoblado   CentroPoblado @relation(fields: [centroPobladoId], references: [id])
  urbano          SectorUrbano?
  rural           SectorRural?

  actoresSociales           ActorSocial[] @relation("ActorSocialSectores")
  actoresSocialesACorregir  ActorSocial[] @relation("ActorSocialSectoresACorregir")
  historialAsignaciones     HistorialAsignacionTerritorial[]
  ninos                     Nino[]

  @@unique([municipalidadId, codigo])
  @@map("sector")
}

model SectorRural {
  sectorId  String @id @map("sector_id") @db.Uuid
  latitud   Float?
  longitud  Float?
  poblacion Int?

  sector Sector @relation(fields: [sectorId], references: [id])

  @@map("sector_rural")
}

model SectorUrbano {
  sectorId String @id @map("sector_id") @db.Uuid
  zona     String @db.VarChar(3)
  manzana  String @db.VarChar(10)

  sector Sector @relation(fields: [sectorId], references: [id])

  @@map("sector_urbano")
}

model ActorSocial {
  id                         String            @id @default(uuid()) @db.Uuid
  usuarioId                  String?           @unique @map("usuario_id") @db.Uuid
  municipalidadId            String            @map("municipalidad_id") @db.Uuid
  tipoActorSocialId          String            @map("tipo_actor_social_id") @db.Uuid
  grupoTrabajoId             String            @map("grupo_trabajo_id") @db.Uuid
  grupoEstablecimientoId     String?           @map("grupo_establecimiento_id") @db.Uuid
  entidadId                  String?           @map("entidad_id") @db.Uuid
  centroPobladoId            String?           @map("centro_poblado_id") @db.Uuid
  dni                        String            @db.VarChar(8)
  nombres                    String            @db.VarChar(150)
  apellidos                  String            @db.VarChar(150)
  direccion                  String            @db.VarChar(200)
  fechaNac                   DateTime          @map("fecha_nac") @db.Date
  email                      String            @db.VarChar(150)
  celular                    String            @db.VarChar(9)
  idiomaOrigen               String            @map("idioma_origen") @db.VarChar(100)
  gradoInstruccion           String            @map("grado_instruccion") @db.VarChar(100)
  estado                     EstadoActorSocial @default(BORRADOR)
  observaciones              String?           @map("observaciones") @db.Text
  activo                     Boolean           @default(true)
  inactivadoPermanentemente  Boolean           @default(false) @map("inactivado_permanentemente")
  archivado                  Boolean           @default(false)
  deletedAt                  DateTime?         @map("deleted_at")
  motivoEliminacion          String?           @map("motivo_eliminacion") @db.Text
  createdAt                  DateTime          @default(now()) @map("created_at")
  updatedAt                  DateTime          @updatedAt @map("updated_at")

  usuario              Usuario?              @relation(fields: [usuarioId], references: [id])
  municipalidad        Municipalidad         @relation(fields: [municipalidadId], references: [id])
  tipoActorSocial      TipoActorSocial       @relation(fields: [tipoActorSocialId], references: [id])
  grupoTrabajo         GrupoTrabajo          @relation(fields: [grupoTrabajoId], references: [id])
  grupoEstablecimiento GrupoEstablecimiento? @relation(fields: [grupoEstablecimientoId], references: [id])
  entidad              Entidad?              @relation(fields: [entidadId], references: [id])
  centroPoblado        CentroPoblado?        @relation(fields: [centroPobladoId], references: [id])

  sectores             Sector[]              @relation("ActorSocialSectores")
  sectoresACorregir    Sector[]              @relation("ActorSocialSectoresACorregir")
  archivos             ActorSocialArchivo[]
  historialAsignaciones HistorialAsignacionTerritorial[]
  asignacionesNinos    AsignacionNinoSocial[]
  visitas              VisitaDomiciliaria[]

  @@unique([municipalidadId, dni])
  @@map("actor_social")
}

model ActorSocialArchivo {
  id            String   @id @default(uuid()) @db.Uuid
  actorSocialId String   @map("actor_social_id") @db.Uuid
  nombreArchivo String   @map("nombre_archivo") @db.VarChar(255)
  rutaArchivo   String   @map("ruta_archivo") @db.Text
  mimeType      String   @map("mime_type") @db.VarChar(100)
  createdAt     DateTime @default(now()) @map("created_at")

  actorSocial   ActorSocial @relation(fields: [actorSocialId], references: [id], onDelete: Cascade)

  @@map("actor_social_archivo")
}

model GrupoTrabajoArchivo {
  id             String   @id @default(uuid()) @db.Uuid
  grupoTrabajoId String   @map("grupo_trabajo_id") @db.Uuid
  nombreArchivo  String   @map("nombre_archivo") @db.VarChar(255)
  rutaArchivo    String   @map("ruta_archivo") @db.Text
  mimeType       String   @map("mime_type") @db.VarChar(100)
  createdAt      DateTime @default(now()) @map("created_at")

  grupoTrabajo   GrupoTrabajo @relation(fields: [grupoTrabajoId], references: [id], onDelete: Cascade)

  @@map("grupo_trabajo_archivo")
}

model CentroPoblado {
  id              String   @id @default(uuid()) @db.Uuid
  municipalidadId String   @map("municipalidad_id") @db.Uuid
  nombre          String   @db.VarChar(150)
  codigo          String?  @db.VarChar(50)
  tipo            String   @db.VarChar(50) // "URBANO" | "RURAL"
  
  // Rural-only fields
  latitud         Float?   @db.DoublePrecision
  longitud        Float?   @db.DoublePrecision
  poblacion       Int?

  activo          Boolean  @default(true)
  archivado       Boolean  @default(false)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  municipalidad   Municipalidad @relation(fields: [municipalidadId], references: [id])
  sectores        Sector[]
  actoresSociales ActorSocial[]

  @@unique([municipalidadId, nombre, tipo])
  @@map("centro_poblado")
}

model HistorialAsignacionTerritorial {
  id              String               @id @default(uuid()) @db.Uuid
  actorSocialId   String               @map("actor_social_id") @db.Uuid
  sectorId        String               @map("sector_id") @db.Uuid
  tipoAccion      TipoAccionAsignacion @map("tipo_accion")
  motivo          String               @db.Text
  creadoPorId     String               @map("creado_por_id") @db.Uuid
  createdAt       DateTime             @default(now()) @map("created_at")

  actorSocial     ActorSocial          @relation(fields: [actorSocialId], references: [id], onDelete: Cascade)
  sector          Sector               @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  creadoPor       Usuario              @relation(fields: [creadoPorId], references: [id])

  @@map("historial_asignacion_territorial")
}

enum SexoNino {
  MASCULINO
  FEMENINO
}

enum EstadoVisita {
  PROGRAMADA
  EJECUTADA
  REPROGRAMADA
  INCONCLUSA
}

model Responsable {
  id              String        @id @default(uuid()) @db.Uuid
  municipalidadId String        @map("municipalidad_id") @db.Uuid
  tipoDocumento   String        @map("tipo_documento") @db.VarChar(20) // "DNI", "CE", etc.
  dni             String        @db.VarChar(15)
  nombres         String        @db.VarChar(150)
  apellidos       String        @db.VarChar(150)
  celular         String?       @db.VarChar(9)
  email           String?       @db.VarChar(150)
  activo          Boolean       @default(true)
  archivado       Boolean       @default(false)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  municipalidad   Municipalidad @relation(fields: [municipalidadId], references: [id])
  ninos           Nino[]

  @@unique([municipalidadId, tipoDocumento, dni])
  @@map("responsable")
}

model Nino {
  id                String                   @id @default(uuid()) @db.Uuid
  municipalidadId   String                   @map("municipalidad_id") @db.Uuid
  responsableId     String                   @map("responsable_id") @db.Uuid
  sectorId          String?                  @map("sector_id") @db.Uuid
  dni               String?                  @db.VarChar(8)
  cnv               String?                  @db.VarChar(20) // Certificado de Nacido Vivo
  nombres           String                   @db.VarChar(150)
  apellidos         String                   @db.VarChar(150)
  sexo              SexoNino
  fechaNac          DateTime                 @map("fecha_nac") @db.Date
  direccion         String                   @db.VarChar(200)
  referencia        String?                  @db.Text
  latitud           Float?                   @db.DoublePrecision
  longitud          Float?                   @db.DoublePrecision
  activo            Boolean                  @default(true)
  archivado         Boolean                  @default(false)
  deletedAt         DateTime?                @map("deleted_at")
  motivoEliminacion String?                  @map("motivo_eliminacion") @db.Text
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  municipalidad     Municipalidad            @relation(fields: [municipalidadId], references: [id])
  responsable       Responsable              @relation(fields: [responsableId], references: [id])
  sector            Sector?                  @relation(fields: [sectorId], references: [id])
  asignaciones      AsignacionNinoSocial[]
  visitas           VisitaDomiciliaria[]

  @@unique([municipalidadId, dni])
  @@map("nino")
}

model AsignacionNinoSocial {
  id            String      @id @default(uuid()) @db.Uuid
  ninoId        String      @map("nino_id") @db.Uuid
  actorSocialId String      @map("actor_social_id") @db.Uuid
  asignadoPorId String      @map("asignado_por_id") @db.Uuid
  motivo        String?     @db.Text
  activo        Boolean     @default(true)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  nino          Nino        @relation(fields: [ninoId], references: [id], onDelete: Cascade)
  actorSocial   ActorSocial @relation(fields: [actorSocialId], references: [id], onDelete: Cascade)
  asignadoPor   Usuario     @relation(fields: [asignadoPorId], references: [id])

  @@map("asignacion_nino_social")
}

model VisitaDomiciliaria {
  id              String       @id @default(uuid()) @db.Uuid
  ninoId          String       @map("nino_id") @db.Uuid
  actorSocialId   String       @map("actor_social_id") @db.Uuid
  fechaProgramada DateTime     @map("fecha_programada") @db.Date
  fechaEjecucion  DateTime?    @map("fecha_ejecucion")
  estado          EstadoVisita @default(PROGRAMADA)
  motivoInconclusa String?     @map("motivo_inconclusa") @db.Text
  peso            Float?       @db.DoublePrecision
  hierroEntregado Boolean?     @map("hierro_entregado")
  consejeriaBrindada Boolean?  @map("consejeria_brindada")
  alertas         String?      @db.Text
  comentarios     String?      @db.Text
  tipoRegistro    String?      @map("tipo_registro") @db.VarChar(100)
  latitud         String?      @db.VarChar(50)
  longitud        String?      @db.VarChar(50)
  evidenciaUrl    String?      @map("evidencia_url") @db.Text
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  nino            Nino         @relation(fields: [ninoId], references: [id], onDelete: Cascade)
  actorSocial     ActorSocial  @relation(fields: [actorSocialId], references: [id], onDelete: Cascade)

  @@map("visita_domiciliaria")
}



